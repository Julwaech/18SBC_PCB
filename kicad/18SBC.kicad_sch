	(text "Precharge curcuit\n- Should activate with power on main battery terminal\n- Precharge for 10 seconds\n- In 10s the voltage on the power bus should have reached\n  the threshold to activate the main mosfets\n- If precharge is unssuccessful (because of a short\n  for example) shut down and wait for power reboot to try again"
		(exclude_from_sim no)
		(at 324.104 29.972 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "84f24a4e-4e77-44f7-b25f-9dcf41bcfdc1")
	)
